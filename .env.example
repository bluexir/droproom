# Server-only. Never expose these with NEXT_PUBLIC_.
AI_PROVIDER=cloudflare
AI_MOCK_MODE=false
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/bytedance/stable-diffusion-xl-lightning

# Optional: set AI_PROVIDER=openai to use OpenAI instead of Cloudflare.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Contract deployment. Never expose DEPLOYER_PRIVATE_KEY with NEXT_PUBLIC_.
BASE_RPC_URL=https://mainnet.base.org
DEPLOYER_PRIVATE_KEY=
DEPLOY_CONFIRMATIONS=2
DROPROOM_CONTRACT_URI=
BASESCAN_API_KEY=

# Public app configuration.
NEXT_PUBLIC_APP_NAME=Droproom
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_FEE_BPS=1000
NEXT_PUBLIC_PLATFORM_WALLET=0x152bB9d22d0a980d915F1052eDEF859A9383b7BF

# Fill after contract deployment, then return to CDP Paymaster allowlist.
NEXT_PUBLIC_DROP_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=8453
