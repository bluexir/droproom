# Server-only. Never expose these with NEXT_PUBLIC_.
AI_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/black-forest-labs/flux-1-schnell
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_URL=
NEXT_PUBLIC_PINATA_GATEWAY_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
BASE_DASHBOARD_API_KEY=

# Optional: set AI_PROVIDER=openai to use OpenAI instead of Cloudflare.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Contract deployment. Never expose DEPLOYER_PRIVATE_KEY with NEXT_PUBLIC_.
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URLS=https://base-rpc.publicnode.com,https://base.drpc.org
DEPLOYER_PRIVATE_KEY=
DEPLOY_CONFIRMATIONS=2
DROPROOM_CONTRACT_URI=
BASESCAN_API_KEY=

# Public app configuration.
NEXT_PUBLIC_APP_NAME=Droproom
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_APP_ID=69db83cb2c63bda0567316af
NEXT_PUBLIC_SUPPORT_EMAIL=support@droproom.app
NEXT_PUBLIC_PLATFORM_FEE_BPS=1000
NEXT_PUBLIC_PLATFORM_WALLET=0x152bB9d22d0a980d915F1052eDEF859A9383b7BF

# Fill after contract deployment. Droproom does not currently sponsor gas or use a paymaster.
NEXT_PUBLIC_DROP_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=8453
